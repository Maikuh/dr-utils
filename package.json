{
  "name": "dr-utils",
  "version": "2.0.1",
  "description": "Set of utilities relevant to the Dominican Republic",
  "author": "Miguel Araujo",
  "license": "MIT",
  "main": "lib/index.js",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "generate-rnc-cedulas": "bun run ./scripts/generate-rnc-cedulas.ts",
    "generate-provincias-municipios": "bun run ./scripts/generate-provincias-municipios.ts",
    "preversion": "bun run lint",
    "prepublishOnly": "bun run lint && bun run build",
    "postversion": "git push --follow-tags",
    "prebuild": "rimraf lib && tsc --noEmit -p tsconfig.build.json",
    "build": "tsdown",
    "format": "biome format --write",
    "lint": "biome lint --write",
    "biome": "biome check --write",
    "biome:ci": "biome ci",
    "test:coverage": "bun test --coverage",
    "bench": "bun run bench/validators.bench.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@types/bun": "^1.3.5",
    "extract-zip": "^2.0.1",
    "rimraf": "^6.1.2",
    "tsdown": "^0.18.4",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.mts",
        "default": "./lib/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      }
    },
    "./errors": {
      "import": {
        "types": "./lib/errors/index.d.mts",
        "default": "./lib/errors/index.mjs"
      },
      "require": {
        "types": "./lib/errors/index.d.ts",
        "default": "./lib/errors/index.js"
      }
    },
    "./types": {
      "import": {
        "types": "./lib/types/index.d.mts",
        "default": "./lib/types/index.mjs"
      },
      "require": {
        "types": "./lib/types/index.d.ts",
        "default": "./lib/types/index.js"
      }
    },
    "./utils": {
      "import": {
        "types": "./lib/utils/index.d.mts",
        "default": "./lib/utils/index.mjs"
      },
      "require": {
        "types": "./lib/utils/index.d.ts",
        "default": "./lib/utils/index.js"
      }
    },
    "./constants": {
      "import": {
        "types": "./lib/constants/index.d.mts",
        "default": "./lib/constants/index.mjs"
      },
      "require": {
        "types": "./lib/constants/index.d.ts",
        "default": "./lib/constants/index.js"
      }
    },
    "./formatters": {
      "import": {
        "types": "./lib/formatters/index.d.mts",
        "default": "./lib/formatters/index.mjs"
      },
      "require": {
        "types": "./lib/formatters/index.d.ts",
        "default": "./lib/formatters/index.js"
      }
    },
    "./validators": {
      "import": {
        "types": "./lib/validators/index.d.mts",
        "default": "./lib/validators/index.mjs"
      },
      "require": {
        "types": "./lib/validators/index.d.ts",
        "default": "./lib/validators/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "dominican republic",
    "republica dominicana",
    "dr",
    "rd",
    "rep dom",
    "dominicano",
    "dominicana",
    "identification",
    "cedula",
    "rnc",
    "registro nacional de contribuyentes",
    "ncf",
    "numero de comprobante fiscal",
    "phone number",
    "telefono",
    "numero telefonico",
    "itbis",
    "tax",
    "impuesto",
    "currency",
    "moneda",
    "plate",
    "placa",
    "validation",
    "validacion",
    "validator",
    "validador",
    "formatter",
    "formateador",
    "util",
    "utils",
    "utilidad",
    "utilidades",
    "helpers"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Maikuh/dr-utils.git"
  },
  "sideEffects": false
}
